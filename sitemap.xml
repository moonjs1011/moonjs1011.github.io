---
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign pages_to_include = site.html_pages | where_exp: "p", "p.sitemap != false" %}
  {% for page in pages_to_include %}
    {% unless page.url contains '/404' %}
  <url>
    <loc>{{ site.url }}{{ page.url | replace: 'index.html', '' }}</loc>
    {% if page.last_modified_at %}
    <lastmod>{{ page.last_modified_at | date: "%Y-%m-%d" }}</lastmod>
    {% elsif page.date %}
    <lastmod>{{ page.date | date: "%Y-%m-%d" }}</lastmod>
    {% endif %}
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
    {% endunless %}
  {% endfor %}
  {% for post in site.posts %}
    {% unless post.sitemap == false %}
  <url>
    <loc>{{ site.url }}{{ post.url }}</loc>
    {% if post.last_modified_at %}
    <lastmod>{{ post.last_modified_at | date: "%Y-%m-%d" }}</lastmod>
    {% else %}
    <lastmod>{{ post.date | date: "%Y-%m-%d" }}</lastmod>
    {% endif %}
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
    {% endunless %}
  {% endfor %}
</urlset>
